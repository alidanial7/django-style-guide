{
  "project_name": "MyProject",
  "project_slug": "{{ cookiecutter.project_name|lower|replace(' ', '_') }}",

  "first_name": "author",
  "last_name": "author lastname",

  "license": "MIT",

  "postgres_user": "user",
  "postgres_password": "password",

  "use_jwt": "y",
  "use_sentry": "n",
  "use_vscode": "n",
  "use_pgadmin": "n",
  "use_redis": "n",
  "use_rabbitmq": "n",
  "use_celery": "n",
  "use_code_style": "n",

  "__prompts__": {
    "project_name": {
      "prompt": "Project name",
      "help": "Display name for your Django project."
    },
    "project_slug": {
      "prompt": "Project slug",
      "help": "Python package name. Press Enter to auto-generate from the project name."
    },
    "first_name": {
      "prompt": "Author first name",
      "help": "Used for project metadata."
    },
    "last_name": {
      "prompt": "Author last name",
      "help": "Used for project metadata."
    },
    "license": {
      "prompt": "License (MIT, BEER, or None)",
      "help": "Choose MIT, BEER, or None (no LICENSE file)."
    },
    "postgres_user": {
      "prompt": "PostgreSQL user",
      "help": "Database user for local Docker Compose and .env defaults."
    },
    "postgres_password": {
      "prompt": "PostgreSQL password",
      "help": "Database password for local Docker Compose and .env defaults."
    },
    "use_jwt": {
      "prompt": "Include JWT authentication (y/n)",
      "help": "Adds users + authentication apps."
    },
    "use_sentry": {
      "prompt": "Include Sentry integration (y/n)",
      "help": "Adds sentry-sdk. Only activates when SENTRY_DSN is set in .env."
    },
    "use_vscode": {
      "prompt": "Include VS Code settings (y/n)",
      "help": "Adds .vscode/settings.json and recommended extensions."
    },
    "use_pgadmin": {
      "prompt": "Include pgAdmin in dev Docker Compose (y/n)",
      "help": "Adds pgAdmin at http://localhost:5050."
    },
    "use_redis": {
      "prompt": "Include Redis (y/n)",
      "help": "Adds Redis to dev Docker Compose and django-redis cache."
    },
    "use_rabbitmq": {
      "prompt": "Include RabbitMQ (y/n)",
      "help": "Message broker. Required when Celery is enabled."
    },
    "use_celery": {
      "prompt": "Include Celery (y/n)",
      "help": "Celery worker + beat. Requires RabbitMQ."
    },
    "use_code_style": {
      "prompt": "Include code style tooling (y/n)",
      "help": "Ruff + pre-commit git hooks."
    }
  },

  "_copy_without_render": []
}
