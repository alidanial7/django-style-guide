{
  "project_name": "MyProject",
  "project_slug": "{{ cookiecutter.project_name|lower|replace(' ', '_') }}",

  "first_name": "author",
  "last_name": "author lastname",

  "license": ["MIT", "BEER", "None"],

  "postgres_user": "user",
  "postgres_password": "password",
  "postgres_version": ["17.10", "16.8", "15.12", "14.17"],

  "use_jwt": ["y", "n"],
  "use_sentry": ["n", "y"],
  "use_vscode": ["n", "y"],
  "use_pgadmin": ["n", "y"],
  "use_redis": ["n", "y"],
  "use_rabbitmq": ["n", "y"],
  "use_celery": ["n", "y"],
  "celery_broker": ["redis", "rabbitmq"],
  "use_asgi": ["n", "y"],
  "use_websockets": ["n", "y"],
  "reverse_proxy": ["none", "nginx", "traefik"],
  "use_code_style": ["y", "n"],
  "use_testing": ["y", "n"],
  "use_ci": ["n", "y"],
  "ci_provider": ["github", "gitlab"],
  "precommit_base": ["y", "n"],
  "precommit_pyupgrade": ["y", "n"],
  "precommit_ruff": ["y", "n"],
  "precommit_pydoclint": ["y", "n"],
  "precommit_translation_lint": ["y", "n"],

  "__prompts__": {
    "project_name": "Project name",
    "project_slug": "Project slug (Python package; Enter = auto from name)",
    "first_name": "Author first name",
    "last_name": "Author last name",
    "license": {
      "__prompt__": "License",
      "MIT": "MIT",
      "BEER": "BEER",
      "None": "None (no LICENSE file)"
    },
    "postgres_user": "PostgreSQL user",
    "postgres_password": "PostgreSQL password",
    "postgres_version": {
      "__prompt__": "PostgreSQL version",
      "17.10": "17.10",
      "16.8": "16.8",
      "15.12": "15.12",
      "14.17": "14.17"
    },
    "use_jwt": {
      "__prompt__": "Authentication mode",
      "y": "JWT (simplejwt)",
      "n": "Session auth"
    },
    "use_sentry": {
      "__prompt__": "Include Sentry?",
      "n": "No",
      "y": "Yes"
    },
    "use_vscode": {
      "__prompt__": "Include VS Code settings?",
      "n": "No",
      "y": "Yes"
    },
    "use_pgadmin": {
      "__prompt__": "Include pgAdmin in dev Compose?",
      "n": "No",
      "y": "Yes"
    },
    "use_redis": {
      "__prompt__": "Include Redis?",
      "n": "No",
      "y": "Yes"
    },
    "use_rabbitmq": {
      "__prompt__": "Include RabbitMQ?",
      "n": "No",
      "y": "Yes"
    },
    "use_celery": {
      "__prompt__": "Include Celery?",
      "n": "No",
      "y": "Yes"
    },
    "celery_broker": {
      "__prompt__": "Celery broker (ignored if Celery is No)",
      "redis": "Redis",
      "rabbitmq": "RabbitMQ"
    },
    "use_asgi": {
      "__prompt__": "Use ASGI (Uvicorn) in production?",
      "n": "No (Gunicorn/WSGI)",
      "y": "Yes (Uvicorn)"
    },
    "use_websockets": {
      "__prompt__": "Include Django Channels / WebSockets? (needs ASGI + Redis)",
      "n": "No",
      "y": "Yes"
    },
    "reverse_proxy": {
      "__prompt__": "Production reverse proxy",
      "none": "None (expose app port)",
      "nginx": "Nginx",
      "traefik": "Traefik"
    },
    "use_code_style": {
      "__prompt__": "Include Ruff + pre-commit?",
      "y": "Yes",
      "n": "No"
    },
    "use_testing": {
      "__prompt__": "Include pytest + default tests?",
      "y": "Yes",
      "n": "No"
    },
    "use_ci": {
      "__prompt__": "Include CI pipeline?",
      "n": "No",
      "y": "Yes"
    },
    "ci_provider": {
      "__prompt__": "CI provider (ignored if CI is No)",
      "github": "GitHub Actions",
      "gitlab": "GitLab CI"
    },
    "precommit_base": {
      "__prompt__": "Pre-commit: file hygiene hooks?",
      "y": "Yes",
      "n": "No"
    },
    "precommit_pyupgrade": {
      "__prompt__": "Pre-commit: pyupgrade?",
      "y": "Yes",
      "n": "No"
    },
    "precommit_ruff": {
      "__prompt__": "Pre-commit: Ruff?",
      "y": "Yes",
      "n": "No"
    },
    "precommit_pydoclint": {
      "__prompt__": "Pre-commit: pydoclint?",
      "y": "Yes",
      "n": "No"
    },
    "precommit_translation_lint": {
      "__prompt__": "Pre-commit: django-translation-lint?",
      "y": "Yes",
      "n": "No"
    }
  },

  "_copy_without_render": []
}
