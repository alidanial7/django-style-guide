SECRET_KEY='=ug_ucl@yi6^mrcjyz%(u0%&g2adt#bz3@yos%#@*t#t!ypx=a'
DATABASE_URL=psql://{{cookiecutter.postgres_user}}:{{cookiecutter.postgres_password}}@127.0.0.1:5432/{{cookiecutter.project_slug}}
{%- if cookiecutter.use_redis == "y" %}
REDIS_LOCATION=redis://localhost:6379
{%- endif %}
{%- if cookiecutter.use_rabbitmq == "y" %}
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
{%- endif %}
{%- if cookiecutter.use_celery == "y" %}
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
{%- endif %}

ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SETTINGS_MODULE=config.django.local
APP_DOMAIN=http://localhost:8000

# CORS (local settings force CORS_ALLOW_ALL_ORIGINS=true; production uses the list below)
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=

# Email (password reset uses console backend by default)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost

# Logging (see README → Logging)
DJANGO_LOGGING_LEVEL=INFO
LOG_TO_FILE=true
LOG_WHEN=midnight
LOG_INTERVAL=1
LOG_BACKUP_COUNT=14
LOG_SQL=false
{%- if cookiecutter.use_jwt == "y" %}

JWT_ACCESS_TOKEN_LIFETIME_SECONDS=900
JWT_REFRESH_TOKEN_LIFETIME_SECONDS=604800
{%- endif %}
{%- if cookiecutter.use_sentry == "y" %}

SENTRY_DSN=
SENTRY_ENVIRONMENT=local
{%- endif %}
