{
  /* -------------------------------------------------------------------------- */
  /*                                 ✏️ editor                                  */
  /* -------------------------------------------------------------------------- */
  "editor.formatOnSave": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.semanticHighlighting.enabled": true,

  /* -------------------------------------------------------------------------- */
  /*                                 🐍 python                                  */
  /* -------------------------------------------------------------------------- */
  "[python]": {
{%- if cookiecutter.use_code_style == "y" %}
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.organizeImports": "never",
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
{%- else %}
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {}
{%- endif %}
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
  "python.analysis.pythonVersion": "3.12",
  "python.terminal.activateEnvironment": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.extraPaths": ["${workspaceFolder}"],
  "python.envFile": "${workspaceFolder}/.env",
{%- if cookiecutter.use_code_style == "y" %}
  "ruff.enable": true,
  "ruff.nativeServer": "on",
  "ruff.lint.enable": true,
  "ruff.format.enable": true,
  "ruff.lineLength": 120,
  "ruff.lint.select": ["E", "F", "W", "I"],
  "ruff.lint.ignore": ["F403"],
  "ruff.organizeImports": true,
  "ruff.fixAll": true,
  "ruff.path": ["${workspaceFolder}/venv/bin/ruff"],
  "ruff.importStrategy": "fromEnvironment",
{%- else %}
  "python.linting.enabled": true,
  "python.linting.flake8Enabled": true,
  "python.linting.flake8Args": ["--max-line-length=120"],
{%- endif %}
  "python.linting.mypyEnabled": true,

  /* -------------------------------------------------------------------------- */
  /*                                 ⚡ emmet                                   */
  /* -------------------------------------------------------------------------- */
  "emmet.includeLanguages": {
    "django-html": "html"
  },
  "[django-html]": {
    "editor.defaultFormatter": "batisteo.vscode-django"
  },

  /* -------------------------------------------------------------------------- */
  /*                                 🔍 search                                  */
  /* -------------------------------------------------------------------------- */
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": true,
    "**/venv": true,
    "**/migrations": true,
    "**/staticfiles": true,
    "**/media": true
  },

  /* -------------------------------------------------------------------------- */
  /*                                 📁 files                                   */
  /* -------------------------------------------------------------------------- */
  "files.associations": {
    "**/templates/**/*.html": "django-html",
    "**/templates/**/*.htm": "django-html"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/*.pyc": true
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/__pycache__/**": true,
    "**/migrations/**": true,
    "**/staticfiles/**": true,
    "**/media/**": true
  },

  /* -------------------------------------------------------------------------- */
  /*                                 🔤 cSpell                                  */
  /* -------------------------------------------------------------------------- */
  "cSpell.enabled": true,
  "cSpell.language": "en",
  "cSpell.words": [
    "authentication",
    "autofetch",
    "batisteo",
{%- if cookiecutter.use_code_style == "y" %}
    "charliermarsh",
{%- endif %}
    "django",
    "djlint",
    "eamodio",
    "middleware",
    "migrations",
    "njpwerner",
    "pagination",
    "pycache",
    "pylance",
    "pytest",
    "queryset",
    "serializer",
    "stackbreak",
    "staticfiles",
    "venv",
    "viewset"
  ],
  "cSpell.ignorePaths": [
    "**/.venv/**",
    "**/venv/**",
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/migrations/**",
    "**/staticfiles/**",
    "**/media/**"
  ],

  /* -------------------------------------------------------------------------- */
  /*                                 📝 autoDocstring                           */
  /* -------------------------------------------------------------------------- */
  "autoDocstring.docstringFormat": "google",
  "autoDocstring.generateDocstringOnEnter": true,
  "autoDocstring.includeExtendedSummary": true,
  "autoDocstring.guessTypes": true,
  "autoDocstring.quoteStyle": "\"\"\"",

  /* -------------------------------------------------------------------------- */
  /*                                 📐 comment-divider                         */
  /* -------------------------------------------------------------------------- */
  "comment-divider.active": true,
  "comment-divider.style": "double-line",
  "comment-divider.char": "=",
  "comment-divider.minLength": 50,
  "comment-divider.maxLength": 80,
  "comment-divider.showEmoji": true,

  /* -------------------------------------------------------------------------- */
  /*                                 🧪 test (pytest)                           */
  /* -------------------------------------------------------------------------- */
{%- if cookiecutter.use_testing == "y" %}
  "python.testing.pytestEnabled": true,
  "python.testing.pytestPath": "${workspaceFolder}/venv/bin/pytest",
  "python.testing.unittestEnabled": false,
  "python.testing.nosetestsEnabled": false,
  "python.testing.cwd": "${workspaceFolder}",
  "python.testing.pytestArgs": ["."],
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.env": {
    "DJANGO_SETTINGS_MODULE": "config.django.test"
  },
{%- else %}
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": false,
{%- endif %}

  /* -------------------------------------------------------------------------- */
  /*                                   🔧 git                                   */
  /* -------------------------------------------------------------------------- */
  "git.autofetch": true
}
